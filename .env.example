# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/blocknote?schema=public"

# ============================================
# JWT AUTHENTICATION
# ============================================
# Secrets for signing login tokens (use random 32+ char strings in production)
JWT_ACCESS_SECRET="change-me-to-a-random-secret-at-least-32-characters"
JWT_REFRESH_SECRET="change-me-to-another-random-secret-at-least-32-characters"

# How long should login token stay valid
ACCESS_TOKEN_EXPIRY="15m"

# How long should user stay logged in without re-authenticating
REFRESH_TOKEN_EXPIRY="7d"

# ============================================
# SERVER CONFIGURATION
# ============================================
# Port to run backend API on
PORT=5000

# Environment (development, production, staging)
NODE_ENV="development"

# Where your frontend is hosted (for CORS)
FRONTEND_URL="http://localhost:5173"

# Backend URL (used for API calls)
BACKEND_URL="http://localhost:5000"

# ============================================
# AI FEATURES
# ============================================
# Get free key from: https://aistudio.google.com/app/apikey
# Required for: Grammar Check, Paraphrase, Summarize features
GEMINI_API_KEY="your_gemini_api_key_here"

